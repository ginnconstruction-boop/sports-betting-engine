# The Odds API Key
ODDS_API_KEY=your_api_key_here

# Optional: Cache window in minutes (default: 5)
CACHE_WINDOW_MINUTES=5

# Optional: Request timeout in ms (default: 10000)
REQUEST_TIMEOUT_MS=10000

# Optional: Log level (debug | info | warn | error)
LOG_LEVEL=info

# Optional: Storage mode (memory | file | postgres)
STORAGE_MODE=file

# Optional: Snapshot directory (for file mode)
SNAPSHOT_DIR=./snapshots


# ============================================================
# BANKROLL CALCULATOR
# Set your bankroll and every pick shows exact dollar suggestion
# ============================================================
BANKROLL=1000

# ============================================================
# EMAIL ALERTS -- A+ picks trigger an email automatically
# Uses Gmail. Create an App Password at myaccount.google.com/security
# ============================================================
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=you@gmail.com
ALERT_EMAIL_FROM=yourapp@gmail.com
ALERT_EMAIL_PASS=your-16-char-app-password
ALERT_MIN_SCORE=88

# ============================================================
# SMS ALERTS -- requires free Twilio account (twilio.com)
# ============================================================
ALERT_SMS_ENABLED=false
ALERT_TWILIO_SID=
ALERT_TWILIO_TOKEN=
ALERT_TWILIO_FROM=+1xxxxxxxxxx
ALERT_PHONE_TO=+1xxxxxxxxxx

# ============================================================
# LINE MOVEMENT MONITOR (Option 27)
# Polls for significant line movement on a configurable interval
# LINE_MONITOR_ENABLED -- set false to disable when you run option 27
# LINE_MONITOR_INTERVAL_MINS -- how often to check (default 60)
# LINE_MONITOR_THRESHOLD_CENTS -- minimum juice move to alert (default 15)
# ============================================================
LINE_MONITOR_ENABLED=true
LINE_MONITOR_INTERVAL_MINS=60
LINE_MONITOR_THRESHOLD_CENTS=15
