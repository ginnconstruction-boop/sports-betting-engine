    "mlbprops": "node --require ts-node/register/transpile-only src/index.ts mlbprops",
    "nhlprops": "node --require ts-node/register/transpile-only src/index.ts nhlprops",
    "nflprops": "node --require ts-node/register/transpile-only src/index.ts nflprops",
    "monitor": "node --require ts-node/register/transpile-only src/index.ts monitor",
    "firstbasket": "node --require ts-node/register/transpile-only src/index.ts firstbasket",
    "firsttd": "node --require ts-node/register/transpile-only src/index.ts firsttd",
    "lategames": "node --require ts-node/register/transpile-only src/index.ts lategames",
    "teasers": "node --require ts-node/register/transpile-only src/index.ts teasers",
    "typecheck": "tsc --noEmit"
