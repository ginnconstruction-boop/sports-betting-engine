    "nba": "node --require ts-node/register/transpile-only src/index.ts nba",
    "mlb": "node --require ts-node/register/transpile-only src/index.ts mlb",
    "nhl": "node --require ts-node/register/transpile-only src/index.ts nhl",
    "ncaab": "node --require ts-node/register/transpile-only src/index.ts ncaab",
    "nfl": "node --require ts-node/register/transpile-only src/index.ts nfl",
    "ncaaf": "node --require ts-node/register/transpile-only src/index.ts ncaaf",
    "ncaa-baseball": "node --require ts-node/register/transpile-only src/index.ts ncaa-baseball",
    "props": "node --require ts-node/register/transpile-only src/index.ts props",
    "clv": "node --require ts-node/register/transpile-only src/index.ts clv",
