    "clv:picks": "node --require ts-node/register/transpile-only src/index.ts clv picks",
    "results": "node --require ts-node/register/transpile-only src/index.ts results",
    "record": "node --require ts-node/register/transpile-only src/index.ts record",
    "week": "node --require ts-node/register/transpile-only src/index.ts week",
    "calibrate": "node --require ts-node/register/transpile-only src/index.ts calibrate",
    "history": "node --require ts-node/register/transpile-only src/index.ts historical",
    "validate": "node --require ts-node/register/transpile-only src/utils/validateSetup.ts",
    "build": "tsc --noEmit && echo 'Type check passed'",
    "altparlays": "node --require ts-node/register/transpile-only src/index.ts altparlays",
    "sgp": "node --require ts-node/register/transpile-only src/index.ts sgp",
    "retro": "node --require ts-node/register/transpile-only src/index.ts retro",
    "fixresults": "node --require ts-node/register/transpile-only src/index.ts fixresults",
    "start": "node --require ts-node/register/transpile-only server.ts",
