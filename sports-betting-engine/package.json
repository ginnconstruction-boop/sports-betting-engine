{
  "name": "sports-betting-engine",
  "version": "2.1.0",
  "description": "Elite sports betting AI — full intelligence stack",
  "main": "dist/index.js",
  "scripts": {
    "mock": "node --require ts-node/register/transpile-only src/dev/mockRun.ts",
    "morning": "node --require ts-node/register/transpile-only src/index.ts morning",
    "midday": "node --require ts-node/register/transpile-only src/index.ts midday",
